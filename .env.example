# ============================================================================
# SENTINEL Shield Configuration - Environment Variables
# ============================================================================
# 
# Copy this file to `.env` and fill in your actual values.
# IMPORTANT: .env is in .gitignore and should NEVER be committed to Git
#
# This ensures your credentials are never exposed in the repository.
# ============================================================================

# Gmail IMAP Configuration
# ============================================================================
# Your Gmail address (use the full email address)
SENTINEL_EMAIL=your-email@gmail.com

# Gmail App Password (NOT your account password!)
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Windows Computer" (or your device)
# 3. Google will generate a 16-character app-specific password
# 4. Copy the full password including any spaces (don't remove them)
# Format: xxxx xxxx xxxx xxxx (16 characters + 3 spaces)
SENTINEL_APP_PASS=xxxx xxxx xxxx xxxx

# IMAP Server Configuration (Optional - defaults to Gmail)
# For Gmail: imap.gmail.com
# For Outlook: imap-mail.outlook.com
# For custom servers: your.imap.server.com
IMAP_SERVER=imap.gmail.com

# IMAP Port (Optional - defaults to 993 for SSL)
IMAP_PORT=993

# Email folder to monitor (Optional - defaults to INBOX)
IMAP_FOLDER=INBOX

# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# 1. NEVER share your App Password or .env file
# 2. If you accidentally commit .env, rotate your credentials immediately
# 3. Check .gitignore to confirm .env is excluded from Git
# 4. Use app-specific passwords, NOT your actual Google password
# 5. Monitor your "Security events" for unauthorized access
#    (https://myaccount.google.com/security-checkup)
#
# ============================================================================
